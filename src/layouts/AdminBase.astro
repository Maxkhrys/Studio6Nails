---
import '@fontsource-variable/cormorant';
import '@fontsource/jost/400.css';
import '@fontsource/jost/500.css';
import '@fontsource/jost/600.css';
import '../styles/global.css';
import AdminNav from '../components/AdminNav.astro';

interface Props {
  title: string;
  active: 'dashboard' | 'availability' | 'services' | 'staff' | 'vouchers' | 'clients';
  role: 'owner' | 'staff';
  name?: string | null;
}
const { title, active, role, name } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>{title} — Studio 6 Nails Admin</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="admin-body">
    <AdminNav active={active} role={role} name={name} />
    <main class="admin-main wrap">
      <slot />
    </main>
  </body>
</html>

<style is:global>
  .admin-body {
    background: var(--porcelain-deep);
    min-height: 100vh;
  }
  .admin-main {
    padding-block: clamp(2rem, 5vw, 3.5rem);
  }
  .admin-h1 {
    font-size: clamp(2rem, 4vw, 3rem);
    margin-bottom: 0.4em;
  }
  .admin-card {
    background: #fff;
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    padding: clamp(1.4rem, 3vw, 2rem);
    margin-bottom: 1.5rem;
  }
  .admin-card h2 {
    font-size: var(--text-h3);
    margin-bottom: 1rem;
  }
  .admin-table {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--text-small);
  }
  .admin-table th,
  .admin-table td {
    text-align: left;
    padding: 0.7em 0.8em;
    border-bottom: 1px solid var(--line-soft);
    vertical-align: middle;
  }
  .admin-table th {
    font-size: var(--text-tiny);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-mid);
  }
  .admin-flash {
    background: #e3efe4;
    border: 1px solid #b8d6bd;
    color: #3d6b48;
    padding: 0.8em 1em;
    border-radius: var(--radius);
    margin-bottom: 1.5rem;
    font-size: var(--text-small);
  }
  .admin-form-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    align-items: flex-end;
  }
  .admin-form-row .field {
    flex: 1 1 8rem;
  }
  .btn-sm {
    padding: 0.5em 1em;
    font-size: var(--text-tiny);
  }
</style>
