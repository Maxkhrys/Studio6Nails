# ---------------------------------------------------------------------------
# Studio 6 Nails — environment variables
# Copy to `.env` for local dev; set the same keys in Vercel for production.
# Nothing here is live until these are filled in.
# ---------------------------------------------------------------------------

# Supabase (Database + Auth) ------------------------------------------------
# Project URL + anon key are safe for the browser; service-role key is
# server-only and must NEVER be exposed to the client.
PUBLIC_SUPABASE_URL=
PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe (deposit payments) -------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Resend (confirmation emails) ---------------------------------------------
RESEND_API_KEY=
# Verified sender + internal notification address
BOOKING_FROM_EMAIL="Studio 6 Nails <onboarding@resend.dev>"
BOOKING_NOTIFY_EMAIL=sarah@studio6nails.ie

# Dojo (FUTURE — in-person balance via Pay at Counter). Not used yet;
# the Stripe adapter is active until these are supplied.
# DOJO_API_KEY=
# DOJO_MERCHANT_ID=
